#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ ! -d "$ROOT/codex-components" ]]; then
  echo "codex-components directory is missing" >&2
  exit 1
fi

if ! mkdir -p "$ROOT/.agents" "$ROOT/.codex"; then
  echo "Could not create .agents/.codex in this environment; codex-components mirror remains available." >&2
  exit 1
fi
rm -rf "$ROOT/.agents/skills" "$ROOT/.codex/agents" "$ROOT/.codex/hooks"
cp -R "$ROOT/codex-components/agents/skills" "$ROOT/.agents/skills"
cp "$ROOT/codex-components/codex/config.toml" "$ROOT/.codex/config.toml"
cp -R "$ROOT/codex-components/codex/agents" "$ROOT/.codex/agents"
cp -R "$ROOT/codex-components/codex/hooks" "$ROOT/.codex/hooks"

echo "Installed Codex components into .agents and .codex"
echo "This includes onboarding, privacy, pilot-package, real-college-pilot, and web-editor skills when present."
echo "Installed skills:"
find "$ROOT/.agents/skills" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
