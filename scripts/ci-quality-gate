#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
OUT_DIR="${CI_OUT_DIR:-out/ci}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --out)
      OUT_DIR="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done
mkdir -p "$OUT_DIR"

dotnet build ThesisDocx.slnx
dotnet test ThesisDocx.slnx

scripts/ci-schema-check
CI_OUT_DIR="$OUT_DIR" scripts/ci-render-examples
CI_OUT_DIR="$OUT_DIR" scripts/ci-template-quality
CI_OUT_DIR="$OUT_DIR" scripts/ci-negative-fixtures

dotnet run --project src/ThesisDocx.Cli -- privacy scan \
  --path examples \
  --out "$OUT_DIR/privacy-scan-examples.json"

dotnet run --project src/ThesisDocx.Cli -- onboarding validate \
  --workspace examples/onboarding/example-engineering-pilot

dotnet run --project src/ThesisDocx.Cli -- onboarding summary \
  --workspace examples/onboarding/example-engineering-pilot \
  --out "$OUT_DIR/onboarding-summary.json" \
  --markdown "$OUT_DIR/onboarding-summary.md"

dotnet run --project src/ThesisDocx.Cli -- onboarding package \
  --workspace examples/onboarding/example-engineering-pilot \
  --out "$OUT_DIR/example-engineering-pilot.template-pilot.zip"

dotnet run --project src/ThesisDocx.Cli -- onboarding package-validate \
  --package "$OUT_DIR/example-engineering-pilot.template-pilot.zip" \
  --out "$OUT_DIR/example-engineering-pilot.package-validate.json"

dotnet run --project src/ThesisDocx.Cli -- ci quality-report \
  --template examples/templates/example-university-engineering \
  --document examples/full-thesis/document.json \
  --requirements examples/requirements/example-engineering-requirements.json \
  --suite examples/template-regression/template-regression-suite.json \
  --negative-fixtures examples/negative-fixtures/negative-fixture-manifest.json \
  --threshold 0.85 \
  --out "$OUT_DIR/quality-report.json" \
  --markdown "$OUT_DIR/quality-report.md"
