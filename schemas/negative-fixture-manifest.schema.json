{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/negative-fixture-manifest.schema.json",
  "title": "NegativeFixtureManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suiteId", "cases"],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["1.0.0"] },
    "suiteId": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/case" }
    }
  },
  "definitions": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(/|[A-Za-z]:[\\\\/])" }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "command", "expectedExitCode", "expectedCodes", "expectedSeverity", "expectedFixHintIds", "notes"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,100}$" },
        "type": { "enum": ["requirement", "template", "document", "baseline", "regression", "gate", "diff", "layout"] },
        "path": { "$ref": "#/definitions/relativePath" },
        "command": { "type": "string", "minLength": 1 },
        "expectedExitCode": { "type": "integer", "minimum": 0, "maximum": 255 },
        "expectedCodes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "expectedSeverity": { "enum": ["info", "warning", "breaking"] },
        "expectedFixHintIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      }
    }
  }
}
