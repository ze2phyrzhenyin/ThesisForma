{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/version-report.schema.json",
  "title": "SchemaVersionReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["reportVersion", "isValid", "checks", "diagnostics"],
  "properties": {
    "reportVersion": { "type": "string", "enum": ["1.0.0"] },
    "isValid": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/definitions/schemaVersionCheck" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/definitions/unifiedDiagnostic" }
    }
  },
  "definitions": {
    "schemaVersionCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "isSupported", "direction", "supportedVersions"],
      "properties": {
        "kind": { "enum": ["thesisDocument", "thesisFormatSpec", "templatePackage"] },
        "version": { "type": "string" },
        "isSupported": { "type": "boolean" },
        "direction": { "enum": ["current", "supported", "old", "future", "missing", "unsupported", "unknown"] },
        "supportedVersions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
        },
        "diagnostic": { "$ref": "#/definitions/unifiedDiagnostic" }
      }
    },
    "unifiedDiagnostic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "severity", "path", "message", "category", "source"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["error", "warning", "info"] },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "fixHint": { "type": "string" },
        "category": {
          "enum": ["schema", "semantic", "template", "rendering", "openxml", "privacy", "requirement", "coverage", "regression", "baseline", "intake", "negativeFixture"]
        },
        "source": { "type": "string", "minLength": 1 },
        "relatedPaths": { "type": "array", "items": { "type": "string" } },
        "details": { "type": "object", "additionalProperties": { "type": "string" } },
        "documentationRef": { "type": "string" }
      }
    }
  }
}
