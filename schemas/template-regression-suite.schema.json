{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/template-regression-suite.schema.json",
  "title": "TemplateRegressionSuite",
  "type": "object",
  "additionalProperties": false,
  "required": ["suiteSchemaVersion", "name", "cases"],
  "properties": {
    "suiteSchemaVersion": {
      "type": "string",
      "enum": ["1.0.0"],
      "description": "Template regression suite schema version."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/case" }
    }
  },
  "definitions": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(/|[A-Za-z]:[\\\\/])" }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "documentPath", "minLayoutSimilarity"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
        },
        "documentPath": { "$ref": "#/definitions/relativePath" },
        "formatPath": { "$ref": "#/definitions/relativePath" },
        "templatePath": { "$ref": "#/definitions/relativePath" },
        "variables": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "minLayoutSimilarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "baselineLayoutPath": { "$ref": "#/definitions/relativePath" },
        "baselineSnapshotPath": { "$ref": "#/definitions/relativePath" },
        "requiredCustomProperties": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredParts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "oneOf": [
        { "required": ["formatPath"] },
        { "required": ["templatePath"] }
      ]
    }
  }
}
