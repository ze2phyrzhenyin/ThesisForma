{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/template-package.schema.json",
  "title": "TemplatePackage",
  "type": "object",
  "additionalProperties": false,
  "required": ["templateSchemaVersion", "id", "name", "version", "locale"],
  "properties": {
    "templateSchemaVersion": { "type": "string", "enum": ["1.0.0"] },
    "id": { "$ref": "#/definitions/id" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "locale": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "description": { "type": "string" },
    "school": { "type": "string" },
    "college": { "type": "string" },
    "degreeType": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "extends": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateId"],
      "properties": {
        "templateId": { "$ref": "#/definitions/id" },
        "versionRange": { "type": "string" }
      }
    },
    "formatSpec": { "type": "object" },
    "formatSpecRef": { "$ref": "#/definitions/relativePath" },
    "variables": { "type": "array", "items": { "$ref": "#/definitions/variable" } },
    "assets": { "type": "array", "items": { "$ref": "#/definitions/asset" } },
    "pageTemplates": { "type": "array", "items": { "$ref": "#/definitions/pageTemplate" } },
    "complianceRules": { "type": "array", "items": { "$ref": "#/definitions/complianceRule" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "anyOf": [
    { "required": ["formatSpec"] },
    { "required": ["formatSpecRef"] },
    { "required": ["extends"] }
  ],
  "definitions": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(/|[A-Za-z]:[\\\\/])" }
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "type"],
      "properties": {
        "name": { "$ref": "#/definitions/id" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "multilineText", "date", "number", "boolean", "enum", "image", "richText"] },
        "required": { "type": "boolean" },
        "defaultValue": {},
        "description": { "type": "string" },
        "sourcePath": { "type": "string", "pattern": "^(metadata|variables)\\.[A-Za-z][A-Za-z0-9_.-]*$" },
        "pattern": { "type": "string" },
        "enumValues": { "type": "array", "items": { "type": "string" } },
        "format": { "type": "string" },
        "displayOrder": { "type": "integer", "minimum": 0 }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "contentType"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "type": { "type": "string", "enum": ["image", "font", "staticDocxFragment", "text"] },
        "path": { "$ref": "#/definitions/relativePath" },
        "contentType": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "pageTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetSectionType", "insertPosition", "blocks"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "targetSectionType": { "type": "string", "enum": ["cover", "declaration", "abstract", "toc", "body", "appendix"] },
        "insertPosition": { "type": "string", "enum": ["beforeSection", "afterSection", "replaceSectionContent"] },
        "pageSetupOverride": { "$ref": "#/definitions/pageSetupOverride" },
        "blocks": { "type": "array", "items": { "$ref": "#/definitions/layoutBlock" } }
      }
    },
    "layoutBlock": {
      "oneOf": [
        { "$ref": "#/definitions/spacerBlock" },
        { "$ref": "#/definitions/textBlock" },
        { "$ref": "#/definitions/metadataFieldBlock" },
        { "$ref": "#/definitions/imageBlock" },
        { "$ref": "#/definitions/fieldTableBlock" },
        { "$ref": "#/definitions/declarationTextBlock" },
        { "$ref": "#/definitions/pageBreakBlock" },
        { "$ref": "#/definitions/ruleBlock" }
      ]
    },
    "spacerBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "heightCm"],
      "properties": {
        "type": { "enum": ["spacer"] },
        "heightCm": { "type": "number", "minimum": 0, "maximum": 20 }
      }
    },
    "textBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "enum": ["text"] },
        "value": { "type": "string" },
        "style": { "type": "string" },
        "alignment": { "$ref": "#/definitions/alignment" },
        "fontOverride": { "type": "object" },
        "spacingBeforePt": { "type": "number", "minimum": 0 },
        "spacingAfterPt": { "type": "number", "minimum": 0 }
      }
    },
    "metadataFieldBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": { "enum": ["metadataField"] },
        "label": { "type": "string" },
        "sourcePath": { "type": "string" },
        "variableName": { "$ref": "#/definitions/id" },
        "valueTemplate": { "type": "string" },
        "layout": { "type": "string", "enum": ["inline", "labelValueLine", "tableRow"] },
        "underline": { "type": "boolean" },
        "alignment": { "$ref": "#/definitions/alignment" }
      }
    },
    "imageBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "assetId"],
      "properties": {
        "type": { "enum": ["image"] },
        "assetId": { "$ref": "#/definitions/id" },
        "widthCm": { "type": "number", "exclusiveMinimum": 0 },
        "heightCm": { "type": "number", "exclusiveMinimum": 0 },
        "alignment": { "$ref": "#/definitions/alignment" }
      }
    },
    "fieldTableBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "rows"],
      "properties": {
        "type": { "enum": ["fieldTable"] },
        "columns": { "type": "integer", "minimum": 1, "maximum": 6 },
        "rows": {
          "type": "array",
          "items": { "type": "array", "items": { "$ref": "#/definitions/metadataFieldBlock" } }
        },
        "borderMode": { "type": "string", "enum": ["none", "full", "bottomLine", "custom"] },
        "labelColumnWidthCm": { "type": "number", "exclusiveMinimum": 0 },
        "valueColumnWidthCm": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "declarationTextBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "paragraphs"],
      "properties": {
        "type": { "enum": ["declarationText"] },
        "paragraphs": { "type": "array", "items": { "type": "string" } },
        "signatureFields": { "type": "array", "items": { "$ref": "#/definitions/metadataFieldBlock" } }
      }
    },
    "pageBreakBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "enum": ["pageBreak"] } }
    },
    "ruleBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["rule"] },
        "thicknessPt": { "type": "number", "exclusiveMinimum": 0, "maximum": 12 },
        "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
        "alignment": { "$ref": "#/definitions/alignment" },
        "spacingBeforePt": { "type": "number", "minimum": 0 },
        "spacingAfterPt": { "type": "number", "minimum": 0 }
      }
    },
    "complianceRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    },
    "pageSetupOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paperSize": { "type": "string", "enum": ["a4", "letter"] },
        "orientation": { "type": "string", "enum": ["portrait", "landscape"] },
        "topMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "bottomMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "leftMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "rightMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "gutterCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "headerDistanceCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "footerDistanceCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "columns": { "type": "integer", "minimum": 1, "maximum": 4 }
      }
    },
    "alignment": { "type": "string", "enum": ["left", "center", "right", "both"] }
  }
}
