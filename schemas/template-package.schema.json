{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/template-package.schema.json",
  "title": "TemplatePackage",
  "type": "object",
  "additionalProperties": false,
  "required": ["templateSchemaVersion", "id", "name", "version", "locale"],
  "properties": {
    "templateSchemaVersion": { "type": "string", "enum": ["1.0.0"] },
    "id": { "$ref": "#/definitions/id" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "locale": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "description": { "type": "string" },
    "school": { "type": "string" },
    "college": { "type": "string" },
    "degreeType": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "extends": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateId"],
      "properties": {
        "templateId": { "$ref": "#/definitions/id" },
        "versionRange": { "type": "string" }
      }
    },
    "formatSpec": { "type": "object" },
    "formatSpecRef": { "$ref": "#/definitions/relativePath" },
    "documentOverrides": { "$ref": "#/definitions/documentOverrides" },
    "variables": { "type": "array", "items": { "$ref": "#/definitions/variable" } },
    "assets": { "type": "array", "items": { "$ref": "#/definitions/asset" } },
    "pageTemplates": { "type": "array", "items": { "$ref": "#/definitions/pageTemplate" } },
    "complianceRules": { "type": "array", "items": { "$ref": "#/definitions/complianceRule" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "anyOf": [
    { "required": ["formatSpec"] },
    { "required": ["formatSpecRef"] },
    { "required": ["extends"] }
  ],
  "definitions": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(/|[A-Za-z]:[\\\\/])" }
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "type"],
      "properties": {
        "name": { "$ref": "#/definitions/id" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "multilineText", "date", "number", "boolean", "enum", "image", "richText"] },
        "required": { "type": "boolean" },
        "defaultValue": {},
        "description": { "type": "string" },
        "sourcePath": { "type": "string", "pattern": "^(metadata|variables)\\.[A-Za-z][A-Za-z0-9_.-]*$" },
        "pattern": { "type": "string" },
        "enumValues": { "type": "array", "items": { "type": "string" } },
        "format": { "type": "string" },
        "displayOrder": { "type": "integer", "minimum": 0 }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "contentType"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "type": { "type": "string", "enum": ["image", "font", "staticDocxFragment", "text"] },
        "path": { "$ref": "#/definitions/relativePath" },
        "contentType": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "pageTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetSectionType", "insertPosition", "blocks"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "targetSectionType": { "type": "string", "enum": ["cover", "declaration", "abstract", "toc", "body", "appendix", "acknowledgements", "bibliography", "teacherComments"] },
        "insertPosition": { "type": "string", "enum": ["beforeSection", "afterSection", "replaceSectionContent"] },
        "targetSectionId": { "$ref": "#/definitions/id" },
        "pageSetupOverride": { "$ref": "#/definitions/pageSetupOverride" },
        "blocks": { "type": "array", "items": { "$ref": "#/definitions/layoutBlock" } }
      }
    },
    "layoutBlock": {
      "oneOf": [
        { "$ref": "#/definitions/spacerBlock" },
        { "$ref": "#/definitions/textBlock" },
        { "$ref": "#/definitions/metadataFieldBlock" },
        { "$ref": "#/definitions/imageBlock" },
        { "$ref": "#/definitions/fieldTableBlock" },
        { "$ref": "#/definitions/declarationTextBlock" },
        { "$ref": "#/definitions/pageBreakBlock" },
        { "$ref": "#/definitions/ruleBlock" },
        { "$ref": "#/definitions/handwritingAreaBlock" }
      ]
    },
    "spacerBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "heightCm"],
      "properties": {
        "type": { "enum": ["spacer"] },
        "heightCm": { "type": "number", "minimum": 0, "maximum": 20 }
      }
    },
    "textBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "enum": ["text"] },
        "value": { "type": "string" },
        "style": { "type": "string" },
        "alignment": { "$ref": "#/definitions/alignment" },
        "fontOverride": { "type": "object" },
        "paragraph": { "$ref": "#/definitions/paragraphOverride" },
        "skipWhenEmpty": { "type": "boolean" },
        "spacingBeforePt": { "type": "number", "minimum": 0 },
        "spacingAfterPt": { "type": "number", "minimum": 0 }
      }
    },
    "metadataFieldBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": { "enum": ["metadataField"] },
        "label": { "type": "string" },
        "sourcePath": { "type": "string" },
        "variableName": { "$ref": "#/definitions/id" },
        "valueTemplate": { "type": "string" },
        "layout": { "type": "string", "enum": ["inline", "labelValueLine", "tableRow"] },
        "underline": { "type": "boolean" },
        "alignment": { "$ref": "#/definitions/alignment" },
        "labelFont": { "$ref": "#/definitions/font" },
        "valueFont": { "$ref": "#/definitions/font" }
      }
    },
    "imageBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "assetId"],
      "properties": {
        "type": { "enum": ["image"] },
        "assetId": { "$ref": "#/definitions/id" },
        "widthCm": { "type": "number", "exclusiveMinimum": 0 },
        "heightCm": { "type": "number", "exclusiveMinimum": 0 },
        "alignment": { "$ref": "#/definitions/alignment" }
      }
    },
    "fieldTableBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "rows"],
      "properties": {
        "type": { "enum": ["fieldTable"] },
        "columns": { "type": "integer", "minimum": 1, "maximum": 6 },
        "rows": {
          "type": "array",
          "items": { "type": "array", "items": { "$ref": "#/definitions/metadataFieldBlock" } }
        },
        "borderMode": { "type": "string", "enum": ["none", "full", "bottomLine", "custom"] },
        "labelColumnWidthCm": { "type": "number", "exclusiveMinimum": 0 },
        "valueColumnWidthCm": { "type": "number", "exclusiveMinimum": 0 },
        "rowHeightPt": { "type": "number", "minimum": 0, "maximum": 144 },
        "labelFont": { "$ref": "#/definitions/font" },
        "valueFont": { "$ref": "#/definitions/font" }
      }
    },
    "declarationTextBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "paragraphs"],
      "properties": {
        "type": { "enum": ["declarationText"] },
        "paragraphs": { "type": "array", "items": { "type": "string" } },
        "signatureFields": { "type": "array", "items": { "$ref": "#/definitions/metadataFieldBlock" } }
      }
    },
    "pageBreakBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "enum": ["pageBreak"] } }
    },
    "ruleBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["rule"] },
        "thicknessPt": { "type": "number", "exclusiveMinimum": 0, "maximum": 12 },
        "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
        "alignment": { "$ref": "#/definitions/alignment" },
        "spacingBeforePt": { "type": "number", "minimum": 0 },
        "spacingAfterPt": { "type": "number", "minimum": 0 }
      }
    },
    "handwritingAreaBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["handwritingArea"] },
        "label": { "type": "string" },
        "heightCm": { "type": "number", "exclusiveMinimum": 0, "maximum": 30 },
        "borderColor": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
        "borderThicknessPt": { "type": "number", "exclusiveMinimum": 0, "maximum": 12 },
        "labelAlignment": { "$ref": "#/definitions/alignment" }
      }
    },
    "complianceRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    },
    "documentOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "toc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
            "maxLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
            "title": { "type": "string", "minLength": 1 },
            "includeSectionIds": { "type": "array", "items": { "$ref": "#/definitions/id" }, "uniqueItems": true }
          }
        },
        "headerFooter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headerText": { "type": "string" },
            "drawHeaderLine": { "type": "boolean" },
            "hidePageNumberOnCover": { "type": "boolean" },
            "differentFirstPage": { "type": "boolean" }
          }
        },
        "defaultFont": { "$ref": "#/definitions/fontOverride" },
        "bodyParagraph": { "$ref": "#/definitions/paragraphOverride" },
        "headings": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[1-6]$": { "$ref": "#/definitions/headingOverride" }
          }
        },
        "sectionFormats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cover": { "$ref": "#/definitions/sectionFormatOverride" },
            "frontMatter": { "$ref": "#/definitions/sectionFormatOverride" },
            "body": { "$ref": "#/definitions/sectionFormatOverride" }
          }
        },
        "sectionInstances": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z0-9][A-Za-z0-9_-]{0,80}$": { "$ref": "#/definitions/sectionInstanceOverride" }
          }
        }
      }
    },
    "font": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eastAsia", "latin", "sizePt"],
      "properties": {
        "eastAsia": { "type": "string", "minLength": 1 },
        "latin": { "type": "string", "minLength": 1 },
        "sizePt": { "type": "number", "minimum": 1, "maximum": 72 },
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" }
      }
    },
    "fontOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eastAsia": { "type": "string", "minLength": 1 },
        "latin": { "type": "string", "minLength": 1 },
        "sizePt": { "type": "number", "minimum": 1, "maximum": 72 },
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" }
      }
    },
    "paragraphOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lineSpacingMultiple": { "type": "number", "minimum": 0.5, "maximum": 4 },
        "lineSpacingExactPt": { "type": ["number", "null"], "minimum": 1, "maximum": 120 },
        "spaceBeforePt": { "type": "number", "minimum": 0, "maximum": 72 },
        "spaceAfterPt": { "type": "number", "minimum": 0, "maximum": 72 },
        "firstLineIndentChars": { "type": "number", "minimum": 0, "maximum": 8 },
        "hangingIndentCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "alignment": { "$ref": "#/definitions/alignment" },
        "widowControl": { "type": "boolean" }
      }
    },
    "headingOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "font": { "$ref": "#/definitions/fontOverride" },
        "spaceBeforePt": { "type": "number", "minimum": 0, "maximum": 72 },
        "spaceAfterPt": { "type": "number", "minimum": 0, "maximum": 72 },
        "numbered": { "type": "boolean" },
        "pageBreakBefore": { "type": "boolean" },
        "outlineLevel": { "type": "integer", "minimum": 0, "maximum": 8 },
        "alignment": { "$ref": "#/definitions/alignment" }
      }
    },
    "sectionFormatOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pageNumberStyle": { "type": "string", "enum": ["none", "decimal", "lowerRoman", "upperRoman"] },
        "startPageNumber": { "type": "integer", "minimum": 1, "maximum": 999 },
        "restartPageNumbering": { "type": "boolean" },
        "includeHeader": { "type": "boolean" },
        "includeFooter": { "type": "boolean" }
      }
    },
    "sectionInstanceOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pageNumberStyle": { "type": "string", "enum": ["none", "decimal", "lowerRoman", "upperRoman"] },
        "startPageNumber": { "type": "integer", "minimum": 1, "maximum": 999 },
        "restartPageNumbering": { "type": "boolean" },
        "includeHeader": { "type": "boolean" },
        "includeFooter": { "type": "boolean" },
        "headerText": { "type": "string" },
        "footerText": { "type": "string" },
        "titleFont": { "$ref": "#/definitions/fontOverride" },
        "titleParagraph": { "$ref": "#/definitions/paragraphOverride" },
        "paragraph": { "$ref": "#/definitions/paragraphOverride" },
        "defaultFont": { "$ref": "#/definitions/fontOverride" },
        "blockOverrides": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[0-9]+$": { "$ref": "#/definitions/blockFormatOverride" }
          }
        }
      }
    },
    "blockFormatOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "font": { "$ref": "#/definitions/fontOverride" },
        "paragraph": { "$ref": "#/definitions/paragraphOverride" }
      }
    },
    "pageSetupOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paperSize": { "type": "string", "enum": ["a4", "letter"] },
        "orientation": { "type": "string", "enum": ["portrait", "landscape"] },
        "topMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "bottomMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "leftMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "rightMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "gutterCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "headerDistanceCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "footerDistanceCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "columns": { "type": "integer", "minimum": 1, "maximum": 4 }
      }
    },
    "alignment": { "type": "string", "enum": ["left", "center", "right", "both"] }
  }
}
