{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/thesis-format-spec.schema.json",
  "title": "ThesisFormatSpec",
  "description": "Declarative formatting rules for deterministic DOCX rendering.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "pageSetup", "defaultFont", "bodyParagraph", "headings", "headerFooter", "toc", "tables", "notes", "figures", "captions", "bibliography", "numbering", "compatibility", "sections", "coverPage"],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["1.0.0", "1.1.0", "1.2.0"] },
    "name": { "type": "string", "minLength": 1 },
    "pageSetup": { "$ref": "#/definitions/pageSetup" },
    "defaultFont": { "$ref": "#/definitions/font" },
    "bodyParagraph": { "$ref": "#/definitions/paragraph" },
    "headings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[1-6]$": { "$ref": "#/definitions/heading" }
      }
    },
    "headerFooter": { "$ref": "#/definitions/headerFooter" },
    "toc": { "$ref": "#/definitions/toc" },
    "tables": { "$ref": "#/definitions/tables" },
    "equations": { "$ref": "#/definitions/equations" },
    "notes": { "$ref": "#/definitions/notes" },
    "figures": { "$ref": "#/definitions/figures" },
    "captions": { "$ref": "#/definitions/captions" },
    "bibliography": { "$ref": "#/definitions/bibliography" },
    "numbering": { "$ref": "#/definitions/numbering" },
    "compatibility": { "$ref": "#/definitions/compatibility" },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cover", "frontMatter", "body"],
      "properties": {
        "cover": { "$ref": "#/definitions/sectionFormat" },
        "frontMatter": { "$ref": "#/definitions/sectionFormat" },
        "body": { "$ref": "#/definitions/sectionFormat" }
      }
    },
    "coverPage": { "$ref": "#/definitions/coverPage" },
    "validation": { "$ref": "#/definitions/validation" }
  },
  "definitions": {
    "pageSetup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paperSize", "orientation", "topMarginCm", "bottomMarginCm", "leftMarginCm", "rightMarginCm", "gutterCm", "headerDistanceCm", "footerDistanceCm", "columns"],
      "properties": {
        "paperSize": { "type": "string", "enum": ["a4", "letter"] },
        "orientation": { "type": "string", "enum": ["portrait", "landscape"] },
        "topMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "bottomMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "leftMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "rightMarginCm": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "gutterCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "headerDistanceCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "footerDistanceCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "columns": { "type": "integer", "minimum": 1, "maximum": 4 }
      }
    },
    "font": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eastAsia", "latin", "sizePt"],
      "properties": {
        "eastAsia": { "type": "string", "minLength": 1 },
        "latin": { "type": "string", "minLength": 1 },
        "sizePt": { "type": "number", "minimum": 1, "maximum": 72 },
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" }
      }
    },
    "paragraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineSpacingMultiple", "spaceBeforePt", "spaceAfterPt", "firstLineIndentChars", "hangingIndentCm", "alignment", "widowControl"],
      "properties": {
        "lineSpacingMultiple": { "type": "number", "minimum": 0.5, "maximum": 4 },
        "lineSpacingExactPt": { "type": ["number", "null"], "minimum": 1, "maximum": 120 },
        "spaceBeforePt": { "type": "number", "minimum": 0, "maximum": 72 },
        "spaceAfterPt": { "type": "number", "minimum": 0, "maximum": 72 },
        "firstLineIndentChars": { "type": "number", "minimum": 0, "maximum": 8 },
        "hangingIndentCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "alignment": { "$ref": "#/definitions/textAlignment" },
        "widowControl": { "type": "boolean" }
      }
    },
    "heading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "font", "spaceBeforePt", "spaceAfterPt", "numbered", "pageBreakBefore", "outlineLevel", "alignment"],
      "properties": {
        "level": { "type": "integer", "minimum": 1, "maximum": 6 },
        "font": { "$ref": "#/definitions/font" },
        "spaceBeforePt": { "type": "number", "minimum": 0, "maximum": 72 },
        "spaceAfterPt": { "type": "number", "minimum": 0, "maximum": 72 },
        "numbered": { "type": "boolean" },
        "pageBreakBefore": { "type": "boolean" },
        "outlineLevel": { "type": "integer", "minimum": 0, "maximum": 8 },
        "alignment": { "$ref": "#/definitions/textAlignment" }
      }
    },
    "headerFooter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headerText", "drawHeaderLine", "headerAlignment", "pageNumberAlignment", "hidePageNumberOnCover", "differentFirstPage", "differentOddEven"],
      "properties": {
        "headerText": { "type": "string" },
        "drawHeaderLine": { "type": "boolean" },
        "headerAlignment": { "$ref": "#/definitions/textAlignment" },
        "pageNumberAlignment": { "$ref": "#/definitions/textAlignment" },
        "hidePageNumberOnCover": { "type": "boolean" },
        "differentFirstPage": { "type": "boolean" },
        "differentOddEven": { "type": "boolean" }
      }
    },
    "toc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "minLevel", "maxLevel", "useWordFieldCode"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "minLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
        "maxLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
        "useWordFieldCode": { "type": "boolean" }
      }
    },
    "tables": {
      "type": "object",
      "additionalProperties": false,
      "required": ["widthPercent", "cellMarginCm", "useThreeLineTables", "captionPosition"],
      "properties": {
        "widthPercent": { "type": "number", "minimum": 1, "maximum": 100 },
        "cellMarginCm": { "type": "number", "minimum": 0, "maximum": 2 },
        "useThreeLineTables": { "type": "boolean" },
        "captionPosition": { "$ref": "#/definitions/legacyCaptionPosition" },
        "defaultAlignment": { "$ref": "#/definitions/textAlignment" },
        "defaultWidth": { "$ref": "#/definitions/tableWidth" },
        "defaultLayout": { "type": "string", "enum": ["autofit", "fixed"] },
        "defaultCellMargins": { "$ref": "#/definitions/cellMargins" },
        "defaultBorders": { "$ref": "#/definitions/borders" },
        "threeLineTableBorders": { "$ref": "#/definitions/borders" },
        "caption": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "position": { "$ref": "#/definitions/captionPosition" },
            "style": { "type": "string", "minLength": 1 },
            "numbering": { "type": "boolean" }
          }
        },
        "repeatHeaderRowsDefault": { "type": "integer", "minimum": 0, "maximum": 20 },
        "allowRowBreakAcrossPagesDefault": { "type": "boolean" }
      }
    },
    "equations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultAlignment": { "$ref": "#/definitions/textAlignment" },
        "fontSizePt": { "type": "number", "minimum": 1, "maximum": 72 },
        "numbering": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "label": { "type": "string", "minLength": 1 },
            "format": { "type": "string", "pattern": "^\\(.*\\{index\\}.*\\)$" },
            "restartByHeadingLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
            "position": { "type": "string", "enum": ["right", "caption"] }
          }
        },
        "spacingBeforePt": { "type": "number", "minimum": 0, "maximum": 72 },
        "spacingAfterPt": { "type": "number", "minimum": 0, "maximum": 72 },
        "captionStyle": { "type": "string", "minLength": 1 },
        "allowLatexFallbackToPlain": { "type": "boolean" },
        "ommlSafetyMode": { "type": "string", "enum": ["strict"] }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["footnote", "endnote"],
      "properties": {
        "footnote": { "$ref": "#/definitions/noteFormat" },
        "endnote": { "$ref": "#/definitions/noteFormat" }
      }
    },
    "noteFormat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["styleId", "font", "paragraph", "superscriptReferenceMark"],
      "properties": {
        "styleId": { "type": "string", "minLength": 1 },
        "font": { "$ref": "#/definitions/font" },
        "paragraph": { "$ref": "#/definitions/paragraph" },
        "superscriptReferenceMark": { "type": "boolean" }
      }
    },
    "figures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultWidthCm", "center", "captionPosition"],
      "properties": {
        "defaultWidthCm": { "type": "number", "exclusiveMinimum": 0, "maximum": 30 },
        "defaultHeightCm": { "type": "number", "exclusiveMinimum": 0, "maximum": 30 },
        "center": { "type": "boolean" },
        "captionPosition": { "$ref": "#/definitions/legacyCaptionPosition" }
      }
    },
    "captions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["figureLabel", "tableLabel", "equationLabel", "separator", "numberFormat"],
      "properties": {
        "figureLabel": { "type": "string", "minLength": 1 },
        "tableLabel": { "type": "string", "minLength": 1 },
        "equationLabel": { "type": "string", "minLength": 1 },
        "separator": { "type": "string" },
        "numberFormat": { "type": "string", "pattern": "\\{label\\}.*\\{number\\}.*\\{text\\}" }
      }
    },
    "bibliography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "entryParagraph", "numberFormat"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "entryParagraph": { "$ref": "#/definitions/paragraph" },
        "numberFormat": { "type": "string", "minLength": 1 }
      }
    },
    "numbering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headingLevel1Text", "headingLevel2Text", "headingLevel3Text", "orderedListText", "bibliographyText"],
      "properties": {
        "headingLevel1Text": { "type": "string", "minLength": 1 },
        "headingLevel2Text": { "type": "string", "minLength": 1 },
        "headingLevel3Text": { "type": "string", "minLength": 1 },
        "orderedListText": { "type": "string", "minLength": 1 },
        "bibliographyText": { "type": "string", "minLength": 1 }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultLanguage", "useEastAsiaFonts", "wordCompatibilityMode"],
      "properties": {
        "defaultLanguage": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
        "useEastAsiaFonts": { "type": "boolean" },
        "wordCompatibilityMode": { "type": "string", "minLength": 1 }
      }
    },
    "sectionFormat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageNumberStyle", "restartPageNumbering", "startPageNumber", "includeHeader", "includeFooter"],
      "properties": {
        "pageNumberStyle": { "type": "string", "enum": ["none", "decimal", "lowerRoman", "upperRoman"] },
        "restartPageNumbering": { "type": "boolean" },
        "startPageNumber": { "type": "integer", "minimum": 1, "maximum": 999 },
        "includeHeader": { "type": "boolean" },
        "includeFooter": { "type": "boolean" }
      }
    },
    "coverPage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fieldOrder"],
      "properties": {
        "fieldOrder": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowHeadingLevelSkips": { "type": "boolean" }
      }
    },
    "legacyCaptionPosition": { "type": "string", "enum": ["above", "below"] },
    "captionPosition": { "type": "string", "enum": ["before", "after"] },
    "tableWidth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["auto", "percent", "dxa"] },
        "value": { "type": "number", "minimum": 0, "maximum": 50000 }
      }
    },
    "borders": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "top": { "$ref": "#/definitions/border" },
        "bottom": { "$ref": "#/definitions/border" },
        "left": { "$ref": "#/definitions/border" },
        "right": { "$ref": "#/definitions/border" },
        "insideH": { "$ref": "#/definitions/border" },
        "insideV": { "$ref": "#/definitions/border" }
      }
    },
    "border": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "style": { "type": "string", "enum": ["nil", "none", "single", "double", "dotted", "dashed"] },
        "size": { "type": "integer", "minimum": 0, "maximum": 96 },
        "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
        "space": { "type": "integer", "minimum": 0, "maximum": 32 }
      }
    },
    "cellMargins": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "bottomCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "leftCm": { "type": "number", "minimum": 0, "maximum": 5 },
        "rightCm": { "type": "number", "minimum": 0, "maximum": 5 }
      }
    },
    "textAlignment": { "type": "string", "enum": ["left", "center", "right", "both"] }
  }
}
