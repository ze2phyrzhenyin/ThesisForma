{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thesisdocx.local/schemas/diagnostic-report.schema.json",
  "title": "DiagnosticReport",
  "type": "object",
  "additionalProperties": true,
  "required": ["status", "summary", "issues", "groupedIssues", "topRecommendedActions", "relatedArtifacts"],
  "properties": {
    "status": { "enum": ["pass", "passWithWarnings", "fail"] },
    "summary": {
      "type": "object",
      "required": ["status", "totalIssues", "breakingIssues", "warnings", "topCategories", "topSpecPaths"],
      "properties": {
        "status": { "type": "string" },
        "totalIssues": { "type": "integer", "minimum": 0 },
        "breakingIssues": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "topCategories": { "type": "array", "items": { "type": "string" } },
        "topSpecPaths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "issues": { "type": "array", "items": { "$ref": "#/definitions/issue" } },
    "diagnostics": { "type": "array", "items": { "$ref": "#/definitions/unifiedDiagnostic" } },
    "versionReport": { "$ref": "#/definitions/versionReport" },
    "groupedIssues": { "type": "array" },
    "topRecommendedActions": { "type": "array", "items": { "type": "string" } },
    "relatedArtifacts": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "definitions": {
    "issue": {
      "type": "object",
      "required": ["id", "source", "category", "severity", "title", "message"],
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "enum": ["info", "warning", "error"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "fixHints": { "type": "array" }
      }
    },
    "unifiedDiagnostic": {
      "type": "object",
      "required": ["code", "severity", "path", "message", "category", "source"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["error", "warning", "info"] },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "fixHint": { "type": "string" },
        "category": {
          "enum": ["schema", "semantic", "template", "rendering", "openxml", "privacy", "requirement", "coverage", "regression", "baseline", "intake", "negativeFixture"]
        },
        "source": { "type": "string", "minLength": 1 },
        "relatedPaths": { "type": "array", "items": { "type": "string" } },
        "details": { "type": "object", "additionalProperties": { "type": "string" } },
        "documentationRef": { "type": "string" }
      }
    },
    "versionReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reportVersion", "isValid", "checks", "diagnostics"],
      "properties": {
        "reportVersion": { "type": "string", "enum": ["1.0.0"] },
        "isValid": { "type": "boolean" },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/definitions/schemaVersionCheck" }
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/definitions/unifiedDiagnostic" }
        }
      }
    },
    "schemaVersionCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "isSupported", "direction", "supportedVersions"],
      "properties": {
        "kind": { "enum": ["thesisDocument", "thesisFormatSpec", "templatePackage"] },
        "version": { "type": "string" },
        "isSupported": { "type": "boolean" },
        "direction": { "enum": ["current", "supported", "old", "future", "missing", "unsupported", "unknown"] },
        "supportedVersions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
        },
        "diagnostic": { "$ref": "#/definitions/unifiedDiagnostic" }
      }
    }
  }
}
