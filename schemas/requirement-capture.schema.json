{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/thesisdocx/requirement-capture.schema.json",
  "title": "RequirementCapture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "school",
    "college",
    "degreeType",
    "locale",
    "sourceDocuments",
    "requirements",
    "mappings",
    "approval"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0"
      ],
      "description": "Requirement capture schema version."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,80}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "school": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "college": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "degreeType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "sourceDocuments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/sourceDocument"
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/requirement"
      }
    },
    "mappings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/mapping"
      }
    },
    "unresolvedItems": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 240
      },
      "default": []
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preparedBy",
        "notes"
      ],
      "properties": {
        "preparedBy": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "reviewedBy": {
          "type": "string",
          "maxLength": 80
        },
        "approvedBy": {
          "type": "string",
          "maxLength": 80
        },
        "approvedAt": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    }
  },
  "definitions": {
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "type",
        "path",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,80}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "type": {
          "enum": [
            "pdf",
            "docx",
            "webpage",
            "manualNote",
            "other"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240,
          "not": {
            "pattern": "^(/|[A-Za-z]:\\\\)"
          }
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shortQuote"
      ],
      "properties": {
        "shortQuote": {
          "type": "string",
          "maxLength": 240,
          "description": "Short excerpt only; do not embed long copyrighted text."
        },
        "page": {
          "type": "string",
          "maxLength": 40
        },
        "section": {
          "type": "string",
          "maxLength": 80
        },
        "screenshotRef": {
          "type": "string",
          "maxLength": 160,
          "not": {
            "pattern": "^(/|[A-Za-z]:\\\\)"
          }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "title",
        "description",
        "sourceId",
        "evidence",
        "normalizedValue",
        "confidence",
        "reviewStatus",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,80}$"
        },
        "category": {
          "enum": [
            "pageSetup",
            "section",
            "font",
            "paragraph",
            "heading",
            "headerFooter",
            "toc",
            "abstract",
            "cover",
            "declaration",
            "table",
            "figure",
            "equation",
            "citation",
            "footnoteEndnote",
            "bibliography",
            "appendix",
            "asset",
            "other"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 140
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "$ref": "#/definitions/evidence"
        },
        "normalizedValue": {
          "type": "string",
          "maxLength": 500
        },
        "targetSpecPath": {
          "$ref": "#/definitions/targetPath"
        },
        "targetTemplatePath": {
          "$ref": "#/definitions/targetPath"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "reviewStatus": {
          "enum": [
            "draft",
            "reviewed",
            "approved",
            "rejected"
          ]
        },
        "reviewer": {
          "type": "string",
          "maxLength": 80
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirementId",
        "mappingStatus",
        "notes"
      ],
      "properties": {
        "requirementId": {
          "type": "string",
          "minLength": 1
        },
        "specPath": {
          "$ref": "#/definitions/targetPath"
        },
        "templatePath": {
          "$ref": "#/definitions/targetPath"
        },
        "mappingStatus": {
          "enum": [
            "unmapped",
            "mapped",
            "partial",
            "notSupported"
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "targetPath": {
      "type": "string",
      "pattern": "^\\$(\\.[A-Za-z][A-Za-z0-9_-]*|\\[[0-9]+\\])*$",
      "maxLength": 180
    }
  }
}
