{
  "schemaVersion": "1.2.0",
  "name": "fictional-cn-theatre-journal-article",
  "pageSetup": {
    "paperSize": "a4",
    "orientation": "portrait",
    "topMarginCm": 2.3,
    "bottomMarginCm": 2.1,
    "leftMarginCm": 2.6,
    "rightMarginCm": 2.4,
    "gutterCm": 0.0,
    "headerDistanceCm": 1.2,
    "footerDistanceCm": 1.4,
    "columns": 1
  },
  "defaultFont": {
    "eastAsia": "宋体",
    "latin": "Times New Roman",
    "sizePt": 10.5,
    "bold": false,
    "italic": false
  },
  "bodyParagraph": {
    "lineSpacingMultiple": 1.15,
    "spaceBeforePt": 0,
    "spaceAfterPt": 4,
    "firstLineIndentChars": 2,
    "hangingIndentCm": 0,
    "alignment": "both",
    "widowControl": true
  },
  "headings": {
    "1": {
      "level": 1,
      "font": {
        "eastAsia": "黑体",
        "latin": "Times New Roman",
        "sizePt": 12,
        "bold": true,
        "italic": false
      },
      "spaceBeforePt": 18,
      "spaceAfterPt": 10,
      "numbered": false,
      "pageBreakBefore": false,
      "outlineLevel": 0,
      "alignment": "center"
    },
    "2": {
      "level": 2,
      "font": {
        "eastAsia": "黑体",
        "latin": "Times New Roman",
        "sizePt": 11,
        "bold": true,
        "italic": false
      },
      "spaceBeforePt": 8,
      "spaceAfterPt": 4,
      "numbered": false,
      "pageBreakBefore": false,
      "outlineLevel": 1,
      "alignment": "left"
    },
    "3": {
      "level": 3,
      "font": {
        "eastAsia": "宋体",
        "latin": "Times New Roman",
        "sizePt": 10.5,
        "bold": true,
        "italic": false
      },
      "spaceBeforePt": 6,
      "spaceAfterPt": 2,
      "numbered": false,
      "pageBreakBefore": false,
      "outlineLevel": 2,
      "alignment": "left"
    }
  },
  "headerFooter": {
    "headerText": "中文戏剧研究辑刊",
    "drawHeaderLine": true,
    "headerAlignment": "center",
    "pageNumberAlignment": "center",
    "oddPageNumberAlignment": "center",
    "evenPageNumberAlignment": "center",
    "hidePageNumberOnCover": false,
    "differentFirstPage": false,
    "differentOddEven": false
  },
  "toc": {
    "title": "目录",
    "minLevel": 1,
    "maxLevel": 2,
    "useWordFieldCode": false
  },
  "tables": {
    "widthPercent": 100,
    "cellMarginCm": 0.1,
    "useThreeLineTables": true,
    "captionPosition": "above",
    "defaultAlignment": "center",
    "defaultWidth": {
      "type": "percent",
      "value": 100
    },
    "defaultLayout": "autofit",
    "defaultCellMargins": {
      "topCm": 0.08,
      "bottomCm": 0.08,
      "leftCm": 0.1,
      "rightCm": 0.1
    },
    "defaultBorders": {
      "top": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "bottom": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "left": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "right": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "insideH": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "insideV": { "style": "single", "size": 4, "color": "000000", "space": 0 }
    },
    "threeLineTableBorders": {
      "top": { "style": "single", "size": 10, "color": "000000", "space": 0 },
      "bottom": { "style": "single", "size": 10, "color": "000000", "space": 0 },
      "left": { "style": "nil", "size": 0, "color": "000000", "space": 0 },
      "right": { "style": "nil", "size": 0, "color": "000000", "space": 0 },
      "insideH": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "insideV": { "style": "nil", "size": 0, "color": "000000", "space": 0 }
    },
    "caption": {
      "position": "before",
      "style": "ThesisCaption",
      "numbering": true
    },
    "repeatHeaderRowsDefault": 1,
    "allowRowBreakAcrossPagesDefault": false
  },
  "equations": {
    "defaultAlignment": "center",
    "fontSizePt": 10.5,
    "numbering": {
      "enabled": true,
      "label": "式",
      "format": "({chapter}.{index})",
      "restartByHeadingLevel": 1,
      "position": "right"
    },
    "spacingBeforePt": 4,
    "spacingAfterPt": 4,
    "captionStyle": "ThesisCaption",
    "allowLatexFallbackToPlain": true,
    "ommlSafetyMode": "strict"
  },
  "notes": {
    "footnote": {
      "styleId": "ThesisFootnoteText",
      "font": {
        "eastAsia": "宋体",
        "latin": "Times New Roman",
        "sizePt": 9,
        "bold": false,
        "italic": false
      },
      "paragraph": {
        "lineSpacingMultiple": 1.0,
        "spaceBeforePt": 0,
        "spaceAfterPt": 0,
        "firstLineIndentChars": 0,
        "hangingIndentCm": 0,
        "alignment": "both",
        "widowControl": true
      },
      "superscriptReferenceMark": true,
      "numberFormat": "decimalEnclosedCircleChinese",
      "numberingRestart": "eachPage",
      "startNumber": 1
    },
    "endnote": {
      "styleId": "ThesisEndnoteText",
      "font": {
        "eastAsia": "宋体",
        "latin": "Times New Roman",
        "sizePt": 9,
        "bold": false,
        "italic": false
      },
      "paragraph": {
        "lineSpacingMultiple": 1.0,
        "spaceBeforePt": 0,
        "spaceAfterPt": 0,
        "firstLineIndentChars": 0,
        "hangingIndentCm": 0,
        "alignment": "both",
        "widowControl": true
      },
      "superscriptReferenceMark": true,
      "numberFormat": "decimalEnclosedCircleChinese",
      "numberingRestart": "continuous",
      "startNumber": 1
    }
  },
  "figures": {
    "defaultWidthCm": 8,
    "defaultHeightCm": 4.5,
    "center": true,
    "captionPosition": "below"
  },
  "captions": {
    "figureLabel": "图",
    "tableLabel": "表",
    "equationLabel": "式",
    "separator": " ",
    "numberFormat": "{label}{number}{separator}{text}"
  },
  "bibliography": {
    "title": "参考文献",
    "entryFont": {
      "eastAsia": "宋体",
      "latin": "Times New Roman",
      "sizePt": 9.5,
      "bold": false,
      "italic": false
    },
    "entryParagraph": {
      "lineSpacingMultiple": 1.0,
      "spaceBeforePt": 0,
      "spaceAfterPt": 2,
      "firstLineIndentChars": 0,
      "hangingIndentCm": 0.74,
      "alignment": "both",
      "widowControl": true
    },
    "numberFormat": "[%1]",
    "sortOrder": "documentOrder"
  },
  "numbering": {
    "headingLevel1Text": "%1.",
    "headingLevel2Text": "%1.%2",
    "headingLevel3Text": "%1.%2.%3",
    "orderedListText": "%1.",
    "bibliographyText": "[%1]"
  },
  "compatibility": {
    "defaultLanguage": "zh-CN",
    "useEastAsiaFonts": true,
    "wordCompatibilityMode": "Word2019"
  },
  "sections": {
    "cover": {
      "pageNumberStyle": "none",
      "restartPageNumbering": true,
      "startPageNumber": 1,
      "includeHeader": false,
      "includeFooter": false
    },
    "frontMatter": {
      "pageNumberStyle": "decimal",
      "restartPageNumbering": true,
      "startPageNumber": 1,
      "includeHeader": true,
      "includeFooter": true
    },
    "body": {
      "pageNumberStyle": "decimal",
      "restartPageNumbering": true,
      "startPageNumber": 1,
      "includeHeader": true,
      "includeFooter": true
    }
  },
  "coverPage": {
    "fieldOrder": ["title", "author", "college", "major", "date"]
  },
  "validation": {
    "allowHeadingLevelSkips": false,
    "bodyTextCount": {
      "min": 1,
      "max": 30000,
      "unit": "nonWhitespaceCharacters",
      "sectionKinds": ["body"]
    }
  }
}
