{
  "templateSchemaVersion": "1.0.0",
  "id": "example-normal-university-humanities",
  "name": "Example Normal University Humanities Thesis",
  "version": "1.0.0",
  "locale": "zh-CN",
  "description": "Fictionalized public humanities thesis template derived from a private onboarding workflow shape. It contains no real source documents or real institution assets.",
  "school": "示例师范大学",
  "college": "示例人文学院",
  "degreeType": "master",
  "tags": ["example", "humanities", "normal-university", "fictionalized"],
  "formatSpecRef": "format-spec.json",
  "variables": [
    {
      "name": "schoolCode",
      "label": "School Code",
      "type": "string",
      "required": true,
      "defaultValue": "10000",
      "description": "Fictional school code shown on the cover.",
      "displayOrder": 1
    },
    {
      "name": "coverThesisType",
      "label": "Cover Thesis Type",
      "type": "enum",
      "required": true,
      "defaultValue": "博士/硕士学位论文",
      "description": "Cover degree label.",
      "enumValues": ["博士/硕士学位论文", "硕士专业学位论文"],
      "displayOrder": 2
    },
    {
      "name": "researchDirection",
      "label": "Research Direction",
      "type": "string",
      "required": false,
      "defaultValue": "中国古代文学",
      "description": "Cover research direction field.",
      "displayOrder": 3
    },
    {
      "name": "completionDate",
      "label": "Completion Date",
      "type": "date",
      "required": true,
      "defaultValue": "2026-05-13",
      "description": "Completion date shown on the cover and declaration signature rows.",
      "format": "yyyy年M月",
      "displayOrder": 4
    }
  ],
  "assets": [
    {
      "id": "normalUniversityWordmark",
      "type": "image",
      "path": "assets/normal-wordmark-placeholder.png",
      "contentType": "image/png",
      "description": "Fictional placeholder wordmark for the public example.",
      "required": true
    }
  ],
  "pageTemplates": [
    {
      "id": "example-normal-humanities-cover",
      "targetSectionType": "cover",
      "insertPosition": "replaceSectionContent",
      "pageSetupOverride": {
        "paperSize": "a4",
        "orientation": "portrait",
        "topMarginCm": 2.54,
        "bottomMarginCm": 2.54,
        "leftMarginCm": 3.17,
        "rightMarginCm": 3.17,
        "gutterCm": 0,
        "headerDistanceCm": 2.0,
        "footerDistanceCm": 2.0,
        "columns": 1
      },
      "blocks": [
        { "type": "spacer", "heightCm": 0.8 },
        {
          "type": "text",
          "value": "学校代码：{{variables.schoolCode}}    学号：{{metadata.studentId}}",
          "style": "ThesisBody",
          "alignment": "left",
          "spacingAfterPt": 8
        },
        { "type": "image", "assetId": "normalUniversityWordmark", "widthCm": 2.0, "heightCm": 2.0, "alignment": "center" },
        { "type": "rule", "thicknessPt": 0.75, "color": "000000", "alignment": "center", "spacingBeforePt": 4, "spacingAfterPt": 8 },
        { "type": "spacer", "heightCm": 0.8 },
        {
          "type": "text",
          "value": "{{variables.coverThesisType}}",
          "style": "ThesisTocTitle",
          "alignment": "center",
          "spacingBeforePt": 8,
          "spacingAfterPt": 18,
          "fontOverride": { "eastAsia": "宋体", "latin": "Times New Roman", "sizePt": 26, "bold": true, "italic": false }
        },
        {
          "type": "text",
          "value": "{{metadata.title}}",
          "style": "ThesisTocTitle",
          "alignment": "center",
          "spacingBeforePt": 12,
          "spacingAfterPt": 24,
          "fontOverride": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 18, "bold": true, "italic": false }
        },
        {
          "type": "fieldTable",
          "columns": 2,
          "borderMode": "bottomLine",
          "labelColumnWidthCm": 3.4,
          "valueColumnWidthCm": 8.8,
          "rows": [
            [{ "type": "metadataField", "label": "学号", "sourcePath": "metadata.studentId", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "学 院", "sourcePath": "metadata.college", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "专 业", "sourcePath": "metadata.major", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "研究方向", "variableName": "researchDirection", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "研究生姓名", "sourcePath": "metadata.author", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "导师", "sourcePath": "metadata.advisor", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "完成日期", "variableName": "completionDate", "layout": "tableRow", "underline": true }]
          ]
        },
        { "type": "pageBreak" }
      ]
    },
    {
      "id": "example-normal-humanities-declarations",
      "targetSectionType": "declaration",
      "insertPosition": "replaceSectionContent",
      "blocks": [
        {
          "type": "text",
          "value": "学位论文独创性声明",
          "style": "ThesisTocTitle",
          "alignment": "center",
          "spacingBeforePt": 15.6,
          "spacingAfterPt": 15.6,
          "fontOverride": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 14, "bold": false, "italic": false }
        },
        {
          "type": "declarationText",
          "paragraphs": [
            "本人声明本论文是在导师指导下独立完成的研究成果。论文中除了特别加以标注和致谢的地方外，不包含其他人或机构已经发表或撰写过的研究成果。其他同志对本研究的启发和所做的贡献均已在论文中做了明确的声明并表示了谢意。"
          ],
          "signatureFields": [
            { "type": "metadataField", "label": "作者签名", "valueTemplate": "{{metadata.author}}", "layout": "labelValueLine", "underline": true, "alignment": "right" },
            { "type": "metadataField", "label": "日期", "variableName": "completionDate", "layout": "labelValueLine", "underline": true, "alignment": "right" }
          ]
        },
        { "type": "spacer", "heightCm": 0.6 },
        {
          "type": "text",
          "value": "学位论文使用授权声明",
          "style": "ThesisTocTitle",
          "alignment": "center",
          "spacingBeforePt": 15.6,
          "spacingAfterPt": 15.6,
          "fontOverride": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 14, "bold": false, "italic": false }
        },
        {
          "type": "declarationText",
          "paragraphs": [
            "本人完全了解示例师范大学有关保留、使用学位论文的规定，即：学校有权保留送交论文的复印件，允许论文被查阅和借阅；学校可以公布论文的全部或部分内容，可以采用影印、缩印或其它手段保存论文。暂缓出版的论文在公开后遵守此规定。"
          ],
          "signatureFields": [
            { "type": "metadataField", "label": "作者签名", "valueTemplate": "{{metadata.author}}", "layout": "labelValueLine", "underline": true, "alignment": "right" },
            { "type": "metadataField", "label": "导师签名", "sourcePath": "metadata.advisor", "layout": "labelValueLine", "underline": true, "alignment": "right" },
            { "type": "metadataField", "label": "日期", "variableName": "completionDate", "layout": "labelValueLine", "underline": true, "alignment": "right" }
          ]
        },
        { "type": "pageBreak" }
      ]
    }
  ],
  "complianceRules": [
    { "id": "normal-humanities-page-setup", "description": "A4 portrait with fixed margins and header/footer distances.", "severity": "warning" },
    { "id": "normal-humanities-heading-shape", "description": "Heading levels 1-3 follow the fictional humanities sample styles.", "severity": "warning" },
    { "id": "normal-humanities-cover-fields", "description": "Cover renders a placeholder mark and structured metadata fields.", "severity": "warning" },
    { "id": "normal-humanities-declarations", "description": "Declaration page renders originality and use-authorization text.", "severity": "warning" }
  ],
  "notes": [
    "Fictional public example for renderer and onboarding tests.",
    "Does not claim compliance with any real institution.",
    "No real source DOCX, extracted text, or real institution asset is included."
  ]
}
