      "level": 1,
      "font": {
        "eastAsia": "黑体",
        "latin": "Times New Roman",
        "sizePt": 16,
        "bold": true,
        "italic": false
      },
      "spaceBeforePt": 15.6,
      "spaceAfterPt": 15.6,
      "numbered": true,
      "pageBreakBefore": true,
      "outlineLevel": 0,
      "alignment": "center"
    },
    "2": {
      "level": 2,
      "font": {
        "eastAsia": "黑体",
        "latin": "Times New Roman",
        "sizePt": 15,
        "bold": false,
        "italic": false
      },
      "spaceBeforePt": 7.8,
      "spaceAfterPt": 7.8,
      "numbered": true,
      "pageBreakBefore": false,
      "outlineLevel": 1,
      "alignment": "center"
    },
    "3": {
      "level": 3,
      "font": {
        "eastAsia": "黑体",
        "latin": "Times New Roman",
        "sizePt": 14,
        "bold": false,
        "italic": false
      },
      "spaceBeforePt": 7.8,
      "spaceAfterPt": 7.8,
      "numbered": true,
      "pageBreakBefore": false,
      "outlineLevel": 2,
      "alignment": "left"
    }
  },
  "headerFooter": {
    "headerText": "示例师范大学研究生学位论文",
    "drawHeaderLine": true,
    "headerAlignment": "center",
    "pageNumberAlignment": "center",
    "hidePageNumberOnCover": true,
    "differentFirstPage": false,
    "differentOddEven": false
  },
  "toc": {
    "title": "目录",
    "minLevel": 1,
    "maxLevel": 3,
    "useWordFieldCode": true
  },
  "tables": {
    "widthPercent": 100,
    "cellMarginCm": 0.1,
    "useThreeLineTables": true,
    "captionPosition": "above",
    "defaultAlignment": "center",
    "defaultWidth": {
      "type": "percent",
      "value": 100
    },
    "defaultLayout": "autofit",
    "defaultCellMargins": {
      "topCm": 0.1,
      "bottomCm": 0.1,
      "leftCm": 0.1,
      "rightCm": 0.1
    },
    "defaultBorders": {
      "top": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "bottom": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "left": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "right": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "insideH": { "style": "single", "size": 4, "color": "000000", "space": 0 },
      "insideV": { "style": "single", "size": 4, "color": "000000", "space": 0 }
    },
    "threeLineTableBorders": {
      "top": { "style": "single", "size": 12, "color": "000000", "space": 0 },
      "bottom": { "style": "single", "size": 12, "color": "000000", "space": 0 },
      "left": { "style": "nil", "size": 0, "color": "000000", "space": 0 },
      "right": { "style": "nil", "size": 0, "color": "000000", "space": 0 },
      "insideH": { "style": "single", "size": 6, "color": "000000", "space": 0 },
      "insideV": { "style": "nil", "size": 0, "color": "000000", "space": 0 }
    },
    "caption": {
      "position": "before",
      "style": "ThesisCaption",
      "numbering": true
    },
    "repeatHeaderRowsDefault": 1,
    "allowRowBreakAcrossPagesDefault": false
  },
  "equations": {
    "defaultAlignment": "center",
    "fontSizePt": 12,
    "numbering": {
      "enabled": true,
      "label": "公式",
      "format": "({chapter}.{index})",
      "restartByHeadingLevel": 1,
      "position": "right"
    },
    "spacingBeforePt": 4,
    "spacingAfterPt": 4,
    "captionStyle": "ThesisCaption",
    "allowLatexFallbackToPlain": true,
    "ommlSafetyMode": "strict"
  },
  "notes": {
    "footnote": {
      "styleId": "ThesisFootnoteText",
      "font": {
        "eastAsia": "宋体",
        "latin": "Times New Roman",
        "sizePt": 10.5,
        "bold": false,
        "italic": false
      },
      "paragraph": {
        "lineSpacingMultiple": 1.0,
        "spaceBeforePt": 0,
        "spaceAfterPt": 0,
        "firstLineIndentChars": 0,
        "hangingIndentCm": 0,
        "alignment": "both",
        "widowControl": true
      },
      "superscriptReferenceMark": true
    },
    "endnote": {
      "styleId": "ThesisEndnoteText",
      "font": {
        "eastAsia": "宋体",
        "latin": "Times New Roman",
        "sizePt": 10.5,
        "bold": false,
        "italic": false
      },
      "paragraph": {
        "lineSpacingMultiple": 1.0,
        "spaceBeforePt": 0,
        "spaceAfterPt": 0,
        "firstLineIndentChars": 0,
        "hangingIndentCm": 0,
        "alignment": "both",
        "widowControl": true
      },
      "superscriptReferenceMark": true
    }
  },
  "figures": {
    "defaultWidthCm": 9,
    "defaultHeightCm": 5,
    "center": true,
    "captionPosition": "below"
  },
  "captions": {
    "figureLabel": "图",
    "tableLabel": "表",
    "equationLabel": "式",
    "separator": " ",
    "numberFormat": "{label}{number}{separator}{text}"
  },
  "bibliography": {
    "title": "参考文献",
    "entryParagraph": {
      "lineSpacingMultiple": 1.67,
      "spaceBeforePt": 0,
      "spaceAfterPt": 0,
      "firstLineIndentChars": 0,
      "hangingIndentCm": 0.74,
      "alignment": "both",
      "widowControl": true
    },
    "numberFormat": "[%1]"
  },
  "numbering": {
    "headingLevel1Text": "第%1章",
    "headingLevel2Text": "第%2节",
    "headingLevel3Text": "%3",
    "orderedListText": "%1.",
    "bibliographyText": "[%1]"
  },
  "compatibility": {
    "defaultLanguage": "zh-CN",
    "useEastAsiaFonts": true,
    "wordCompatibilityMode": "Word2019"
  },
  "sections": {
    "cover": {
      "pageNumberStyle": "none",
      "restartPageNumbering": true,
      "startPageNumber": 1,
      "includeHeader": false,
      "includeFooter": false
    },
    "frontMatter": {
      "pageNumberStyle": "upperRoman",
      "restartPageNumbering": true,
      "startPageNumber": 1,
      "includeHeader": true,
      "includeFooter": true
    },
    "body": {
      "pageNumberStyle": "decimal",
      "restartPageNumbering": true,
      "startPageNumber": 1,
      "includeHeader": true,
      "includeFooter": true
    }
  },
  "coverPage": {
    "fieldOrder": ["studentId", "title", "college", "major", "author", "advisor", "date"]
  },
  "validation": {
    "allowHeadingLevelSkips": false
  }
}
