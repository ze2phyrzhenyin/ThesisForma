{
  "templateSchemaVersion": "1.0.0",
  "id": "example-university-humanities",
  "name": "Example University Humanities Thesis",
  "version": "1.0.0",
  "locale": "zh-CN",
  "description": "Fictional humanities college thesis template with a distinct cover, declaration, abstract notice, and humanities-oriented formatting.",
  "school": "Example University",
  "college": "Example Humanities College",
  "degreeType": "master",
  "tags": ["example", "humanities", "template"],
  "formatSpecRef": "format-spec.json",
  "documentOverrides": {
    "sectionInstances": {
      "abstract-cn": {
        "titleFont": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 16, "bold": true },
        "titleParagraph": { "lineSpacingMultiple": 1.0, "spaceBeforePt": 0, "spaceAfterPt": 8, "firstLineIndentChars": 0, "hangingIndentCm": 0, "alignment": "center", "widowControl": true },
        "blockOverrides": {
          "1": {
            "font": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 12, "bold": true },
            "paragraph": { "lineSpacingMultiple": 1.0, "spaceBeforePt": 0, "spaceAfterPt": 0, "firstLineIndentChars": 0, "hangingIndentCm": 0, "alignment": "left", "widowControl": true }
          }
        }
      }
    }
  },
  "variables": [
    {
      "name": "submissionDate",
      "label": "Submission Date",
      "type": "date",
      "required": true,
      "defaultValue": "2026-06-15",
      "description": "Date used on the cover and declaration signature rows.",
      "format": "yyyy年M月d日",
      "displayOrder": 1
    },
    {
      "name": "researchField",
      "label": "Research Field",
      "type": "string",
      "required": false,
      "defaultValue": "数字人文",
      "description": "Research field shown on the cover.",
      "displayOrder": 2
    },
    {
      "name": "reviewStatus",
      "label": "Review Status",
      "type": "enum",
      "required": false,
      "defaultValue": "公开评阅",
      "description": "Fictional review marker rendered on the cover.",
      "enumValues": ["公开评阅", "匿名评阅"],
      "displayOrder": 3
    }
  ],
  "assets": [
    {
      "id": "humanitiesSeal",
      "type": "image",
      "path": "assets/humanities-seal-placeholder.png",
      "contentType": "image/png",
      "description": "Placeholder seal for the fictional humanities college.",
      "required": true
    }
  ],
  "pageTemplates": [
    {
      "id": "humanities-cover",
      "targetSectionType": "cover",
      "insertPosition": "replaceSectionContent",
      "pageSetupOverride": {
        "paperSize": "a4",
        "orientation": "portrait",
        "topMarginCm": 2.8,
        "bottomMarginCm": 2.2,
        "leftMarginCm": 3.1,
        "rightMarginCm": 2.3,
        "gutterCm": 0,
        "headerDistanceCm": 1.2,
        "footerDistanceCm": 1.6,
        "columns": 1
      },
      "blocks": [
        { "type": "spacer", "heightCm": 1.0 },
        { "type": "image", "assetId": "humanitiesSeal", "widthCm": 1.8, "heightCm": 1.8, "alignment": "center" },
        {
          "type": "text",
          "value": "{{template.school}}",
          "style": "ThesisTocTitle",
          "alignment": "center",
          "spacingBeforePt": 10,
          "spacingAfterPt": 4,
          "fontOverride": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 18, "bold": true }
        },
        { "type": "text", "value": "{{template.college}}", "style": "ThesisBody", "alignment": "center", "spacingAfterPt": 18 },
        { "type": "rule", "thicknessPt": 0.75, "color": "555555", "alignment": "center", "spacingBeforePt": 0, "spacingAfterPt": 10 },
        {
          "type": "text",
          "value": "{{metadata.title}}",
          "style": "ThesisTocTitle",
          "alignment": "center",
          "spacingBeforePt": 8,
          "spacingAfterPt": 18
        },
        {
          "type": "fieldTable",
          "columns": 2,
          "borderMode": "full",
          "labelColumnWidthCm": 3.2,
          "valueColumnWidthCm": 9.8,
          "rowHeightPt": 24,
          "labelFont": { "eastAsia": "黑体", "latin": "Times New Roman", "sizePt": 12, "bold": true },
          "valueFont": { "eastAsia": "楷体", "latin": "Times New Roman", "sizePt": 12, "bold": false },
          "rows": [
            [{ "type": "metadataField", "label": "作者", "sourcePath": "metadata.author", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "学号", "sourcePath": "metadata.studentId", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "学院", "sourcePath": "metadata.college", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "专业", "sourcePath": "metadata.major", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "研究方向", "variableName": "researchField", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "导师", "sourcePath": "metadata.advisor", "layout": "tableRow", "underline": true }],
            [{ "type": "metadataField", "label": "提交日期", "variableName": "submissionDate", "layout": "tableRow", "underline": true }]
          ]
        },
        { "type": "metadataField", "label": "评阅方式", "variableName": "reviewStatus", "layout": "labelValueLine", "alignment": "center" },
        { "type": "pageBreak" }
      ]
    },
    {
      "id": "humanities-declaration",
      "targetSectionType": "declaration",
      "insertPosition": "replaceSectionContent",
      "blocks": [
        { "type": "text", "value": "学术诚信声明", "style": "ThesisTocTitle", "alignment": "center", "spacingAfterPt": 12 },
        {
          "type": "declarationText",
          "paragraphs": [
            "本人声明所提交的学位论文是在导师指导下独立完成的研究成果。",
            "文中引用他人观点、材料或数据处均已按学术规范注明来源。"
          ],
          "signatureFields": [
            { "type": "metadataField", "label": "作者签名", "valueTemplate": "签名：{{metadata.author}}", "layout": "labelValueLine", "underline": true, "alignment": "right" },
            { "type": "metadataField", "label": "日期", "variableName": "submissionDate", "layout": "labelValueLine", "underline": true, "alignment": "right" }
          ]
        },
        { "type": "handwritingArea", "label": "学院审核意见", "heightCm": 3, "borderColor": "555555", "borderThicknessPt": 0.75, "labelAlignment": "left" },
        { "type": "pageBreak" }
      ]
    },
    {
      "id": "humanities-abstract-note",
      "targetSectionType": "abstract",
      "targetSectionId": "abstract-cn",
      "insertPosition": "beforeSection",
      "blocks": [
        {
          "type": "text",
          "value": "{{template.college}} 摘要页",
          "style": "ThesisBody",
          "alignment": "center",
          "spacingAfterPt": 6,
          "fontOverride": { "eastAsia": "楷体", "latin": "Times New Roman", "sizePt": 12, "bold": false }
        }
      ]
    }
  ],
  "complianceRules": [
    { "id": "humanities-cover-fields", "description": "Cover must show author, student id, college, major, research field, advisor, and submission date.", "severity": "warning" },
    { "id": "humanities-declaration-text", "description": "Declaration page must include academic integrity text and signature fields.", "severity": "warning" },
    { "id": "humanities-abstract-note", "description": "Abstract page includes a fictional college abstract marker.", "severity": "info" }
  ],
  "notes": [
    "Fictional template for tests and examples only.",
    "Does not claim compliance with any real college format."
  ]
}
